{
    "name": "sistemas-eel/portal-ui",
    "description": "Biblioteca de UI Blade-first reutilizável para sistemas Laravel.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "laravel",
        "blade",
        "theme",
        "layout",
        "ui"
    ],
    "require": {
        "php": "^7.4|^8.0|^8.1|^8.2|^8.3|^8.4",
        "illuminate/support": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0",
        "illuminate/view": "^8.0|^9.0|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^6.47|^7.56|^8.37|^9.17|^10.11|^11.1",
        "phpunit/phpunit": "^9.6|^10.5|^11.5"
    },
    "autoload": {
        "psr-4": {
            "SistemasEel\\PortalUi\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SistemasEel\\PortalUi\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit"
    },
    "extra": {
        "laravel": {
            "providers": [
                "SistemasEel\\PortalUi\\PortalUiServiceProvider"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
